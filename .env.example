APP_ENV=development
DEBUG=false
APP_NAME=TamGam
APP_VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Local development DB URL (not used in Cloud Run production mode).
DATABASE_URL=postgresql+psycopg2://tamgam:tamgam_pass@localhost:5432/tamgam

# JWT
JWT_SECRET_KEY=replace-with-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# DB pool tuning (use smaller values for low-cost Cloud SQL tiers).
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=2
DB_POOL_RECYCLE_SECONDS=1800

# Keep Redis disabled at launch to minimize fixed costs.
REDIS_URL=
REDIS_REQUIRED=false

# GCP
GCP_PROJECT_ID=your-project-id
GCP_REGION=asia-south1
VERTEX_AI_LOCATION=asia-south1
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# Cloud Tasks (optional; start with disabled for lower cost).
CLOUD_TASKS_ENABLED=false
CLOUD_TASKS_QUEUE=tamgam-jobs
CLOUD_TASKS_LOCATION=asia-south1
CLOUD_TASKS_PROJECT_ID=your-project-id
CLOUD_TASKS_TARGET_URL=
CLOUD_TASKS_AUTH_SECRET=

# Cloud SQL production variables (required only when APP_ENV=production).
DB_USER=
DB_PASS=
DB_NAME=tamgam
DB_CONNECTION_NAME=project:region:instance

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_PATH=

# Google Drive / service account
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# Gemini API key pool fallback
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# Storage buckets
GCS_PUBLIC_BUCKET=tamgam-public
GCS_PRIVATE_BUCKET=tamgam-docs-private

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=

# Email
SENDGRID_API_KEY=
EMAIL_FROM=noreply@tamgam.in
EMAIL_FROM_NAME=TamGam
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=true
EMAIL_LOGIN_CODE_TTL_MINUTES=10
EMAIL_LOGIN_CODE_RESEND_COOLDOWN_SECONDS=45
EMAIL_LOGIN_CODE_MAX_ATTEMPTS=5
